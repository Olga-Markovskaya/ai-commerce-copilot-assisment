# Fixed ports for stable local development - do not auto-change
PORT=4000

# Allowed browser origin for CORS (Vite dev server)  
CLIENT_ORIGIN=http://localhost:5173

# Client API base URL (create client/.env with VITE_API_BASE_URL=http://localhost:4000)

# OpenAI API configuration (server-side only)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-5.4-mini
OPENAI_MAX_COMPLETION_TOKENS=400

# SQLite database path
SQLITE_DB_PATH=./data/app.db

# DummyJSON API base URL
DUMMYJSON_BASE_URL=https://dummyjson.com
